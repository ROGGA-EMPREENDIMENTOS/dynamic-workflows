{
    "name": "rogga/dynamic-workflows",
    "description": "A Laravel package for configuring business rule workflows via Filament v3.",
    "type": "library",
    "version": "1.4.2",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "livewire/livewire": "^3.0|^4.0",
        "filament/actions": "^3.0|^5.0",
        "filament/forms": "^3.0|^5.0",
        "filament/support": "^3.0|^5.0",
        "filament/tables": "^3.0|^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Rogga\\DynamicWorkflows\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rogga\\DynamicWorkflows\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rogga\\DynamicWorkflows\\DynamicWorkflowsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
